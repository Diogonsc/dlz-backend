{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "event-bus:replay-dlq": "curl -sS -X POST \"${API_URL:-http://127.0.0.1:3333}/api/v1/internal/event-bus/dlq/replay\" -H \"Authorization: Bearer ${EVENT_BUS_ADMIN_TOKEN}\" -H 'Content-Type: application/json' -d '{\"limit\":50}'"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "fastify": "^5.2.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.0.0",
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/cache-manager": "^3.0.0",
    "@nestjs/websockets": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/schedule": "^5.0.1",
    "@keyv/redis": "^4.2.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^9.0.3",
    "socket.io": "^4.8.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "redis": "^4.7.0",
    "stripe": "^17.7.0",
    "mercadopago": "^2.8.0",
    "@aws-sdk/client-s3": "^3.750.0",
    "web-push": "^3.6.7",
    "@dlz/prisma": "workspace:*",
    "@dlz/shared": "workspace:*",
    "@prisma/client": "^6.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.0.0",
    "cache-manager": "^6.0.0",
    "cache-manager-ioredis-yet": "^2.0.0",
    "ioredis": "^5.4.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.0.0",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.25.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/web-push": "^3.6.4",
    "@types/multer": "^1.4.12",
    "@types/jsonwebtoken": "^9.0.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.8.0"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.(t|j)s$": "ts-jest" },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
