# =============================================================================
# DLZ Backend — Variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env com valores reais
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3333
API_URL=http://localhost:3333
FRONTEND_URL=http://localhost:5173

# ── Banco de dados ────────────────────────────────────────────────────────────
POSTGRES_USER=dlz
POSTGRES_PASSWORD=dlz_secret
POSTGRES_DB=dlz_db
DATABASE_URL=postgresql://dlz:dlz_secret@localhost:5432/dlz_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=troque-por-uma-string-longa-e-aleatoria-min-64-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=outro-secret-longo-para-refresh-token
JWT_REFRESH_EXPIRES_IN=7d

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

# ── Cakto ─────────────────────────────────────────────────────────────────────
CAKTO_WEBHOOK_SECRET=...

# ── MercadoPago ───────────────────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
MERCADOPAGO_WEBHOOK_SECRET=...

# ================================
# PAYMENT GATEWAY HEALTH (MERCADO PAGO)
# ================================

# Habilita execução do cron de health
# Valores aceitos: true/false (evite 1/0 para não gerar ambiguidade)
# - Se não definido: default = true em produção, false em dev/test
# - Recomenda-se manter true em produção
PAYMENT_GATEWAY_HEALTH_CRON_ENABLED=true

# Quantos tenants serão avaliados por ciclo do cron
# - Evita sobrecarga no Mercado Pago
# - Ajustar conforme volume de tenants ativos
# - Recomendado: 50–200
PAYMENT_GATEWAY_HEALTH_CRON_LIMIT=100

# Número máximo de validações simultâneas
# - Controla pressão no gateway externo
# - Muito alto pode causar rate limit
# - Recomendado: 3–10
PAYMENT_GATEWAY_HEALTH_CRON_CONCURRENCY=5

# Delay aleatório antes de iniciar o cron (ms)
# - Evita múltiplas instâncias começarem juntas
# - Importante em ambientes com autoscaling
PAYMENT_GATEWAY_HEALTH_CRON_JITTER_MS=2000

# Tempo de vida do lock Redis (ms)
# - Deve ser menor que o intervalo do cron (5min)
# - Evita execução duplicada entre instâncias
PAYMENT_GATEWAY_HEALTH_CRON_LOCK_TTL_MS=240000

# TTL do cache de validação (segundos)
# - Evita chamadas repetidas ao Mercado Pago
# - Recomendado: 300 (5 minutos)
PAYMENT_GATEWAY_HEALTH_CACHE_TTL_SECONDS=300

# ⚠️ Produção:
# - Este cron deve rodar em apenas UMA instância (garantido via Redis lock)
# - Não aumentar concorrência sem avaliar rate limits do Mercado Pago
# - Monitorar logs: payment_gateway_health_cron

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
WHATSAPP_TOKEN=...
WHATSAPP_PHONE_NUMBER_ID=...
WHATSAPP_BUSINESS_ACCOUNT_ID=...
WHATSAPP_WEBHOOK_VERIFY_TOKEN=...

# ── iFood ─────────────────────────────────────────────────────────────────────
IFOOD_CLIENT_ID=...
IFOOD_CLIENT_SECRET=...

# ── Storage (Cloudflare R2 ou AWS S3) ─────────────────────────────────────────
STORAGE_ENDPOINT=https://<account>.r2.cloudflarestorage.com
STORAGE_BUCKET=dlz-assets
STORAGE_ACCESS_KEY=...
STORAGE_SECRET_KEY=...
STORAGE_PUBLIC_URL=https://assets.dlz.app.br

# ── Push notifications (VAPID) ────────────────────────────────────────────────
VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:contato@dlz.app.br

# ── Traefik / Domínio (produção) ──────────────────────────────────────────────
API_DOMAIN=api.dlz.app.br
ACME_EMAIL=contato@dlz.app.br
GITHUB_REPO=Diogonsc/dlz-backend

# ── Vercel (domínios customizados) ─────────────────────────────────────────────
VERCEL_TOKEN=...
VERCEL_PROJECT_ID=prj_...

# ── Twilio (WhatsApp alternativo) ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_NUMBER=+14155238886
TWILIO_MOCK=false

# ── Snapshots mensais (cron) ───────────────────────────────────────────────────
MONTHLY_SNAPSHOTS_SECRET=secret-longo-aqui
